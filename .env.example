# Vercel KV (Redis) - for leaderboard and prize claiming
# These are automatically set by Vercel when you create a KV store
# For local development, copy these from your Vercel project settings
KV_REST_API_URL=your_kv_rest_api_url
KV_REST_API_TOKEN=your_kv_rest_api_token

# Optional: Admin password for future admin panel
# ADMIN_PASSWORD=your_secure_password_here
